{
  "private": true,
  "type": "module",
  "name": "cross-stitch-dueling-bot",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "postinstall": "nuxt prepare",
    "|-------- APP --------|": "",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "|-------- DATABASE --------|": "",
    "migrate:up": "node-pg-migrate up --database-url-var NUXT_DATABASE_URL",
    "migrate:down": "node-pg-migrate down --database-url-var NUXT_DATABASE_URL",
    "migrate:redo": "node-pg-migrate redo --database-url-var NUXT_DATABASE_URL",
    "migrate:create": "node-pg-migrate create --migration-file-language sql --migration-filename-format index",
    "db:load-mockdata": "cat fixtures/mockdata.sql | docker exec -i cross-stitch-dueling-bot-database psql -U user -d cross-stitch-dueling-bot -q",
    "|-------- SERVICES --------|": "",
    "services:up": "docker compose up -d && sleep 2 && npm run migrate:up && node scripts/create-buckets.js",
    "services:down": "docker compose down",
    "|-------- UTILS --------|": "",
    "check-types": "nuxt typecheck",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@fluent/bundle": "0.19.1",
    "@google-cloud/storage": "7.19.0",
    "@google-cloud/tasks": "6.2.1",
    "@grammyjs/auto-retry": "2.0.2",
    "@grammyjs/i18n": "1.1.2",
    "@nuxt/ui": "4.5.1",
    "@roziscoding/grammy-autoquote": "2.0.9",
    "@tanstack/vue-table": "8.21.3",
    "@telegram-apps/init-data-node": "2.0.10",
    "@vueuse/core": "13.9.0",
    "awilix": "13.0.3",
    "dayjs": "1.11.20",
    "dotenv": "17.3.1",
    "es-toolkit": "1.45.1",
    "fluent-vue": "3.8.2",
    "google-auth-library": "10.6.1",
    "google-gax": "5.0.6",
    "grammy": "1.41.1",
    "h3": "1.15.6",
    "mime-types": "3.0.2",
    "nuxt": "4.4.2",
    "nuxt-auth-utils": "0.5.29",
    "ofetch": "1.5.1",
    "slonik": "48.13.2",
    "vue": "3.5.30",
    "vue-router": "5.0.3",
    "wasm-image-optimization": "2.0.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.98",
    "@nuxt/eslint": "1.15.2",
    "@types/mime-types": "3.0.1",
    "@types/telegram-web-app": "9.1.3",
    "@vue/eslint-config-prettier": "10.2.0",
    "eslint": "10.1.0",
    "eslint-plugin-yml": "3.3.1",
    "node-pg-migrate": "9.0.0-alpha.6",
    "prettier": "3.8.1",
    "prettier-plugin-sql": "0.19.2",
    "semantic-release": "25.0.3",
    "semantic-release-export-data": "1.2.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "unplugin-fluent-vue": "1.4.1",
    "vue-tsc": "3.2.5"
  }
}
